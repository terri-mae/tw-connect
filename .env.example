# ─────────────────────────────────────────────────────────
#  TW Connect  –  Environment Variables
#  Copy this file to .env and fill in the values below.
#  The .env file must NEVER be committed to version control.
# ─────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────
# Port the Express API listens on (default: 3001)
PORT=3001

# Environment: development | production
NODE_ENV=development

# ── Security ──────────────────────────────────────────────
# JWT secret — generate a strong random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

# Session duration in hours (default: 8)
SESSION_HOURS=8

# ── CORS ──────────────────────────────────────────────────
# The origin your React app is served from.
# In development: http://localhost:5173 (Vite dev server)
# In production:  https://yourdomain.com
CLIENT_ORIGIN=http://localhost:5173

# ── Database ──────────────────────────────────────────────
# Path to the SQLite database file (relative to the server/ directory).
# Default: ../database/twconnect.db  (do not change unless you know why)
# DB_PATH=../database/twconnect.db
